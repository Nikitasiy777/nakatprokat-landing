hildren":[["$","li",null,{"style":{"fontSize":"15px","color":"var(--text-sub)","lineHeight":1.7,"fontWeight":500},"children":"Фамилия, имя (или псевдоним);"}],["$","li",null,{"style":{"fontSize":"15px","color":"var(--text-sub)","lineHeight":1.7,"fontWeight":500},"children":"Номер телефона;"}],["$","li",null,{"style":{"fontSize":"15px","color":"var(--text-sub)","lineHeight":1.7,"fontWeight":500},"children":"Адрес электронной почты (при наличии);"}],["$","li",null,{"style":{"fontSize":"15px","color":"var(--text-sub)","lineHeight":1.7,"fontWeight":500},"children":"Иные сведения, которые Пользователь самостоятельно указывает в полях форм."}]]}],["$","p",null,{"style":{"fontSize":"15px","color":"var(--text-sub)","lineHeight":1.7,"fontWeight":500},"children":"Оператор не обрабатывает специальные категории персональных данных (расовая принадлежность, политические взгляды, религиозные убеждения, состояние здоровья, биометрические данные)."}]]}]]}],["$","section",null,{"children":[["$","h2",null,{"style":{"fontSize":"18px","fontWeight":800,"color":"var(--text-primary)","marginBottom":16},"children":"3. Цели обработки персональных данных"}],["$","div",null,{"style":{"display":"flex","flexDirection":"column","gap":12},"children":[["$","p",null,{"style":{"fontSize":"15px","color":"var(--text-sub)","lineHeight":1.7,"fontWeight":500},"children":"Персональные данные обрабатываются в следующих целях:"}],["$","ul",null,{"style":{"paddingLeft":20,"display":"flex","flexDirection":"column","gap":6},"children":[["$","li",null,{"style":{"fontSize":"15px","color":"var(--text-sub)","lineHeight":1.7,"fontWeight":500},"children":"Рассмотрение заявки Пользователя на трудоустройство курьером и обратная связь по заявке;"}],["$","li",null,{"style":{"fontSize":"15px","color":"var(--text-sub)","lineHeight":1.7,"fontWeight":500},"children":"Консультирование Пользователя по вопросам условий работы и оформления документов;"}],["$","li",null,{"style":{"fontSize":"15px","color":"var(--text-sub)","lineHeight":1.7,"fontWeight":500},"children":"Направление информационных сообщений, непосредственно связанных с обработкой заявки (при наличии согласия);"}],["$","li",null,{"style":{"fontSize":"15px","color":"var(--text-sub)","lineHeight":1.7,"fontWeight":500},"children":"Исполнение требований законодательства Российской Федерации."}]]}]]}]]}],["$","section",null,{"children":[["$","h2",null,{"style":{"fontSize":"18px","fontWeight":800,"color":"var(--text-primary)","marginBottom":16},"children":"4. Правовое основание обработки"}],["$","div",null,{"style":{"display":"flex","flexDirection":"column","gap":12},"children":[["$","p",null,{"style":{"fontSize":"15px","color":"var(--text-sub)","lineHeight":1.7,"fontWeight":500},"children":"Правовым основанием для обработки персональных данных является согласие субъекта персональных данных (ст. 6, ч. 1, п. 1 Федерального закона № 152-ФЗ), выражаемое путём проставления соответствующей отметки в форме на Сайте."}],["$","p",null,{"style":{"fontSize":"15px","color":"var(--text-sub)","lineHeight":1.7,"fontWeight":500},"children":"Персональные данные не обрабатываются без предварительного получения соответствующего согласия."}]]}]]}],["$","section",null,{"children":[["$","h2",null,{"style":{"fontSize":"18px","fontWeight":800,"color":"var(--text-primary)","marginBottom":16},"children":"5. Порядок и условия обработки"}],["$","div",null,{"style":{"display":"flex","flexDirection":"column","gap":12},"children":[["$","p",null,{"style":{"fontSize":"15px","color":"var(--text-sub)","lineHeight":1.7,"fontWeight":500},"children":"Обработка персональных данных осуществляется с соблюдением принципов и правил, предусмотренных Федеральным законом № 152-ФЗ. Оператор обрабатывает персональные данные как с использованием средств автоматизации, так и без их использования."}],["$","p",null,{"style":{"fontSize":"15px","color":"var(--text-sub)","lineHeight":1.7,"fontWeight":500},"children":"Оператор обязуется не осуществлять продажу, передачу персональных данных третьим лицам в коммерческих целях."}],["$","p",null,{"style":{"fontSize":"15px","color":"var(--text-sub)","lineHeight":1.7,"fontWeight":500},"children":"Персональные данные могут быть переданы третьим лицам только в случаях, предусмотренных действующим законодательством Российской Федерации (по запросу суда, правоохранительных органов, иных уполномоченных государственных органов)."}],["$","p",null,{"style":{"fontSize":"15px","color":"var(--text-sub)","lineHeight":1.7,"fontWeight":500},"children":"Трансграничная передача персональных данных не осуществляется."}]]}]]}],["$","section",null,{"children":[["$","h2",null,{"style":{"fontSize":"18px","fontWeight":800,"color":"var(--text-primary)","marginBottom":16},"children":"6. Сроки хранения персональных данных"}],["$","div",null,{"style":{"display":"flex","flexDirection":"column","gap":12},"children":[["$","p",null,{"style":{"fontSize":"15px","color":"var(--text-sub)","lineHeight":1.7,"fontWeight":500},"children":"Персональные данные хранятся в течение срока, необходимого для достижения целей их обработки, либо до момента отзыва согласия субъектом персональных данных, но не дольше трёх лет с момента предоставления."}],["$","p",null,{"style":{"fontSize":"15px","color":"var(--text-sub)","lineHeight":1.7,"fontWeight":500},"children":"По истечении указанного срока, а также после удовлетворения всех претензий, персональные данные уничтожаются."}]]}]]}],["$","section",null,{"children":[["$","h2",null,{"style":{"fontSize":"18px","fontWeight":800,"color":"var(--text-primary)","marginBottom":16},"children":"7. Защита персональных данных"}],["$","div",null,{"style":{"display":"flex","flexDirection":"column","gap":12},"children":[["$","p",null,{"style":{"fontSize":"15px","color":"var(--text-sub)","lineHeight":1.7,"fontWeight":500},"children":"Оператор принимает необходимые организационные и технические меры для защиты персональных данных от неправомерного доступа, уничтожения, изменения, блокирования, копирования, распространения, а также от иных неправомерных действий в отношении персональных данных:"}],["$","ul",null,{"style":{"paddingLeft":20,"display":"flex","flexDirection":"column","gap":6},"children":[["$","li",null,{"style":{"fontSize":"15px","color":"var(--text-sub)","lineHeight":1.7,"fontWeight":500},"children":"передача данных по защищённому протоколу HTTPS;"}],["$","li",null,{"style":{"fontSize":"15px","color":"var(--text-sub)","lineHeight":1.7,"fontWeight":500},"children":"ограничение доступа к персональным данным только уполномоченным сотрудникам;"}],["$","li",null,{"style":{"fontSize":"15px","color":"var(--text-sub)","lineHeight":1.7,"fontWeight":500},"children":"обязательство сотрудников, имеющих доступ к ПД, соблюдать конфиденциальность."}]]}]]}]]}],["$","section",null,{"children":[["$","h2",null,{"style":{"fontSize":"18px","fontWeight":800,"color":"var(--text-primary)","marginBottom":16},"children":"8. Права субъекта персональных данных"}],["$","div",null,{"style":{"display":"flex","flexDirection":"column","gap":12},"children":[["$","p",null,{"style":{"fontSize":"15px","color":"var(--text-sub)","lineHeight":1.7,"fontWeight":500},"children":"Пользователь имеет право:"}],["$","ul",null,{"style":{"paddingLeft":20,"display":"flex","flexDirection":"column","gap":6},"children":[["$","li",null,{"style":{"fontSize":"15px","color":"var(--text-sub)","lineHeight":1.7,"fontWeight":500},"children":"получить подтверждение факта обработки своих персональных данных Оператором (ст. 14 № 152-ФЗ);"}],["$","li",null,{"style":{"fontSize":"15px","color":"var(--text-sub)","lineHeight":1.7,"fontWeight":500},"children":"получить доступ к своим персональным данным и сведениям об их обработке;"}],["$","li",null,{"style":{"fontSize":"15px","color":"var(--text-sub)","lineHeight":1.7,"fontWeight":500},"children":"требовать уточнения, блокирования или уничтожения своих персональных данных в случае их неполноты, устаревания, недостоверности, незаконного получения или нецелесообразности дальнейшей обработки;"}],["$","li",null,{"style":{"fontSize":"15px","color":"var(--text-sub)","lineHeight":1.7,"fontWeight":500},"children":"отозвать согласие на обработку персональных данных в любое время, направив письменный запрос на электронную почту Оператора;"}],["$","li",null,{"style":{"fontSize":"15px","color":"var(--text-sub)","lineHeight":1.7,"fontWeight":500},"children":"обжаловать действия или бездействие Оператора в Роскомнадзор (rkn.gov.ru) или в судебном порядке."}]]}],["$","p",null,{"style":{"fontSize":"15px","color":"var(--text-sub)","lineHeight":1.7,"fontWeight":500},"children":["Для реализации прав Пользователь вправе направить запрос на адрес электронной почты: ",["$","a",null,{"href":"mailto:nakatprokat@yandex.ru","style":{"color":"var(--lime-dark)"},"children":"nakatprokat@yandex.ru"}],". Ответ на запрос предоставляется в течение 30 дней."]}]]}]]}],["$","section",null,{"children":[["$","h2",null,{"style":{"fontSize":"18px","fontWeight":800,"color":"var(--text-primary)","marginBottom":16},"children":"9. Использование файлов Cookie"}],["$","div",null,{"style":{"display":"flex","flexDirection":"column","gap":12},"children":[["$","p",null,{"style":{"fontSize":"15px","color":"var(--text-sub)","lineHeight":1.7,"fontWeight":500},"children":"Сайт может использовать файлы Cookie для обеспечения корректной работы сервисов, улучшения пользовательского опыта и сбора обезличенной статистики. Cookie не содержат персональных данных, достаточных для идентификации конкретного физического лица."}],["$","p",null,{"style":{"fontSize":"15px","color":"var(--text-sub)","lineHeight":1.7,"fontWeight":500},"children":"Пользователь вправе отключить использование Cookie в настройках браузера. В этом случае часть функций Сайта может работать некорректно."}]]}]]}],["$","section",null,{"children":[["$","h2",null,{"style":{"fontSize":"18px","fontWeight":800,"color":"var(--text-primary)","marginBottom":16},"children":"10. Изменение Политики"}],["$","div",null,{"style":{"display":"flex","flexD